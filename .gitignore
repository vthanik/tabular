# Local-only Claude Code files
CLAUDE.local.md
MEMORY.md
plan.md
build.md
debugging.md
[Hh]andoff*.md
HANDOFF*.md
.local/

# R session/state
*.Rproj
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# pkgdown build output / installed vignettes
docs/
inst/doc/

# Quarto render cache + per-vignette render artefacts (vignettes are .qmd).
# Scoped to vignettes/ so it never shadows tracked snapshot .html under
# tests/testthat/_snaps/.
.quarto/
*.quarto_ipynb
vignettes/**/*_files/
vignettes/*.html
vignettes/articles/*.html

# data-raw transient
data-raw/cache/

# testthat per-test scratch / failure-report artefacts
tests/testthat/_problems/
tests/testthat/testthat-problems.rds

# macOS
.DS_Store

# Microsoft Word / LibreOffice lockfiles — created when an editor
# opens a .rtf / .docx snapshot for inspection; never commit.
~$*

# Latex compile artefacts (from smoke tests / examples that
# shell out to xelatex)
*.log
*.aux
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
handoff.md
/doc/
/Meta/

# Claude Code local harness state (settings, schedule locks)
.claude/
