\if{html}{\out{<div class="sourceCode r">}}\preformatted{# Demographics layout: variable as section header, stat_label
# as visible suppressed column.
cols(
  variable   = col_spec(usage = "group", group_display = "header_row"),
  stat_label = col_spec(usage = "group", group_display = "column"),
  placebo    = col_spec(label = "Placebo", align = "decimal")
)
}\if{html}{\out{</div>}}}

\item{group_skip}{\emph{Insert a blank row between consecutive groups.}
\verb{<logical(1)>: default NA}. Active only when \code{usage = "group"} —
setting it on a non-group column is ignored and warns. Three values:
\itemize{
\item \strong{\code{TRUE}} — engine injects one blank row immediately before
each value transition on this column (PROC REPORT's \verb{BREAK AFTER var / SKIP} semantics, lifted to per-column control).
Never trails the final group.
\item \strong{\code{FALSE}} — never insert a blank row for this column.
\item \strong{\code{NA}} \emph{(default)} — follow \code{group_display}: \code{TRUE} when
\code{group_display = "header_row"}, \code{FALSE} when \code{"column"} or
\code{"column_repeat"}. Picks the canonical shape
without an extra knob to set.
}

\strong{Interaction:} When two or more columns have an effective
\code{group_skip = TRUE} and their value transitions coincide on the
same row, the engine emits ONE blank row at that boundary, not
one per column. Transition row indices are unioned across all
contributing group columns.

\if{html}{\out{<div class="sourceCode r">}}\preformatted{# Default: header_row mode auto-injects blanks between sections.
col_spec(usage = "group", group_display = "header_row")

# Override: keep the column visible (suppressed-value mode) but
# still insert blank-row separators between value changes.
col_spec(usage = "group", group_display = "column", group_skip = TRUE)

# Override: section headers without the blank-row separator
# (denser layout, used when vertical space is tight).
col_spec(usage = "group", group_display = "header_row", group_skip = FALSE)

# Break-only "spacer": pairs with visible = FALSE to drop a blank
# line wherever a hidden marker changes, without rendering the
# column or any header row. group_display is ignored when hidden.
col_spec(usage = "group", group_skip = TRUE, visible = FALSE)
}\if{html}{\out{</div>}}}

\item{align}{\emph{Horizontal alignment within the column.}
\verb{<character(1) | NULL>: default NULL}. One of:
\itemize{
\item \strong{\code{"left"}} — character columns; row labels.
\item \strong{\code{"center"}} — column-header band; rarely on data cells.
\item \strong{\code{"right"}} — numeric content without decimals.
\item \strong{\code{"decimal"}} — numeric or mixed-format cells aligned on
the decimal mark. Use for \code{"5 (3.2\%)"} next to
\code{"54 (32.1\%)"}.
\item \strong{\code{NULL}} (default) — falls through to
\code{preset(alignment = list(body_halign = ...))} and then to
the baked default \code{"left"}.
}

\strong{Tip:} \code{"decimal"} pads numerics with non-breaking spaces
so the decimal mark falls on a single column-wide anchor.
Pad counts follow the active preset's \code{decimal_metrics} knob
(see \code{\link[=preset]{preset()}}): the default \code{"afm"} measures real glyph
widths so the anchor holds in proportional fonts as well as
monospace.

\strong{Default behaviour.} When \code{align} is unset (\code{NULL} / \code{NA}),
every column emits with body left-aligned and header centred,
regardless of the column's R data type. tabular's canonical
input is pre-summarised wide data frames where numeric content
is already formatted as character strings (e.g. \code{"52 (60.5)"}),
so \code{is.numeric()}-based auto-detection would mis-classify those
columns as text and align them left — the opposite of intent.
Use explicit \code{align = "decimal"} for NBSP-padded numeric
columns (centred header over the padded centroid) or
\code{align = "right"} for plain right-aligned numeric columns.
The default cascade is body → \code{preset(alignment = list( body_halign = ...))} → CSS \code{text-align: left}; header →
\code{preset(alignment = list(header_halign = ...))} → CSS
\code{text-align: center}.}

\item{valign}{\emph{Vertical alignment within the cell.}
\verb{<character(1) | NULL>: default NULL}. One of \code{"top"},
\code{"middle"}, \code{"bottom"}. \code{NULL} falls through to
\code{preset(alignment = list(body_valign = ...))} (baked default
\code{"top"}). Per-cell overrides via \code{style(valign = ...)} still
win over the column setting.

\strong{Tip:} Set \code{"middle"} on the row-label column of a banded-
row table so the label stays centred against the multi-line
stat-block in the adjacent cell.}

\item{na_text}{\emph{Text substituted for \code{NA} cells.}
\verb{<character(1) | NA>: default NA}. Substituted BEFORE the \code{format}
step, so \code{format} does not need to anticipate \code{NA}. \code{NA} (default)
inherits the preset's table-wide \code{na_text}; any string overrides it
for this column, including \code{""} to force blank cells even when the
preset uses a non-empty token.

\strong{Tip:} Use a sentinel (\code{"-"}, \code{"NR"}, \code{"."}) when blank cells
would be ambiguous, e.g. when "not applicable" and "not
reported" both render blank.}

\item{indent}{\emph{Cosmetic indent depth on this column.}
\verb{<numeric(1) | character(1) | NA>: default NA}. Two modes by type:
\itemize{
\item \strong{A non-negative whole number} — every body row of this column
is indented that many levels (each level is
\code{preset@indent_size} space-widths). \code{indent = 1} is the common
"nudge this stub in one level" case; \code{indent = 0} is a real
value that flattens children under a \code{"header_row"} section.
\item \strong{A column name (character)} — per-row depth: the engine reads
\code{spec@data[[indent]]}, coerces each row to a non-negative
integer, and prefixes that row's text + AST with
\code{strrep(" ", preset@indent_size * depth)}. The referenced depth
column is auto-hidden — no need to set \code{visible = FALSE} on it.
}

\code{NA} (default) means no indent. Backends with native padding-left
(HTML / LaTeX / RTF / DOCX / PDF) emit the depth as cell padding so
wrapped continuation lines align with the indented baseline;
Markdown carries the literal space-prefix. Synthesised group-header
rows are never indented — they are the parent at depth 0.

\strong{Interaction:} an explicit \code{indent} on a
\code{group_display = "header_row"} host \strong{suppresses} that section's
automatic one-level child indent (you take control of the depth) —
so a stub under a section needs no \code{indent} at all, and adding
\code{indent = 1} there yields a single, not double, indent.

Per-row SOC / PT pattern (the bundled \code{cdisc_saf_aesocpt} ships the
canonical depth column, so no upstream construction is needed):

\if{html}{\out{<div class="sourceCode r">}}\preformatted{cols(
  label    = col_spec(label = "Category", indent = "indent_level"),
  soc      = col_spec(visible = FALSE),
  row_type = col_spec(visible = FALSE)
)
}\if{html}{\out{</div>}}

Depth-column values \verb{c(0L, 1L, 2L, …)} produce \code{0}, \code{1}, \code{2}, …
levels. Negative values clamp to 0 (warn); fractional numerics
floor (warn); NA → 0 (silent). Works in flat listings too — a
character \code{indent} does not require any \code{usage = "group"} columns.}
}
\value{
\emph{A \code{col_spec} S7 object.} Pass it to \code{\link[=cols]{cols()}} keyed by
the input column name; the constructor itself does not stamp
a name.
}
\description{
Build a single column's display attributes — usage, label, format,
visibility, width, alignment, NA text. The result feeds \code{\link[=cols]{cols()}},
which stamps the input column name onto the spec from its named-
argument position and attaches it to the parent \code{tabular_spec}.
}
\details{
\strong{Constructor-only.} \code{col_spec()} does not know which input
column it belongs to until \code{\link[=cols]{cols()}} stamps the name. Build
reusable specs as ordinary R objects (e.g.
\code{arm_col <- col_spec(align = "decimal")}) and apply them to
multiple inputs without restating the name.

\strong{Merge semantics across repeated \code{cols()} calls.} When
\code{\link[=cols]{cols()}} is called twice for the same column, the engine merges
field-by-field: any field set to a non-default value on the new spec
overrides; a field left at its "unset" sentinel (\code{NA} / \code{NULL} /
\code{"auto"}) leaves the existing value intact. Because every mergeable
field has a genuine unset sentinel, a later call can also \emph{restore} a
default — e.g. \code{visible = TRUE} re-shows a column an earlier call
hid. Build a column's spec in stages without re-stating earlier
attributes.

\strong{Validation timing.} Argument shapes are validated eagerly —
a malformed \code{sprintf} template is probed at construction
(\code{sprintf(format, 0)}) and fails fast at write time, not at
render time.
}
\examples{
# ---- Example 1: Demographics with every col_spec field exercised ----
#
# Demographics table where every `col_spec` field is in play:
# the row-label columns are pinned to a fixed width and aligned
# left, the four arm columns embed BigN inline in the header,
# decimal-align numeric content, and render `NA` cells as "-".
n <- stats::setNames(cdisc_saf_n$n, cdisc_saf_n$arm_short)

tabular(
  cdisc_saf_demo,
  titles = c(
    "Table 14.1.1",
    "Demographics and Baseline Characteristics",
    "Safety Population"
  ),
  footnotes = "Percentages based on N per treatment group."
) |>
  cols(
    variable   = col_spec(
      usage = "group", label = "Parameter",
      width = 2.0,     align = "left"
    ),
    stat_label = col_spec(label = "Statistic", align = "left"),
    placebo  = col_spec(
      label = "Placebo\nN={n['placebo']}",
      align = "decimal", na_text = "-"
    ),
    drug_50  = col_spec(
      label = "Drug 50\nN={n['drug_50']}",
      align = "decimal", na_text = "-"
    ),
    drug_100 = col_spec(
      label = "Drug 100\nN={n['drug_100']}",
      align = "decimal", na_text = "-"
    ),
    Total    = col_spec(
      label = "Total\nN={n['Total']}",
      align = "decimal", na_text = "-"
    )
  ) |>
  sort_rows(by = c("variable", "stat_label"))

# ---- Example 2: AE table with indented label + hidden helpers ----
#
# AE-by-SOC/PT table where `label` carries both the SOC and the PT
# text in one column, each PT indented one level under its parent
# SOC via `indent_level`. The hidden numeric helpers `soc_n` (the
# parent SOC's count, broadcast across its PT children) and
# `n_total` (each row's own count) drive the sort: ordering by
# `soc_n` descending keeps every SOC cluster together, and the
# `n_total` descending tiebreak floats the SOC summary row above
# its PTs, so the table reads SOC then its PTs, next SOC then its
# PTs. Demonstrates `indent` plus `visible = FALSE` for sort-only
# columns, fixed width on the wide label column, and decimal
# alignment on all four arm columns.
n <- stats::setNames(cdisc_saf_n$n, cdisc_saf_n$arm_short)

tabular(
  cdisc_saf_aesocpt,
  titles = c(
    "Table 14.3.1",
    "Adverse Events by SOC and Preferred Term",
    "Safety Population"
  )
) |>
  cols(
    label    = col_spec(label = "SOC / Preferred Term",
                        indent = "indent_level", width = 2.5),
    soc      = col_spec(visible = FALSE),
    row_type = col_spec(visible = FALSE),
    soc_n    = col_spec(visible = FALSE),
    n_total  = col_spec(visible = FALSE),
    placebo  = col_spec(label = "Placebo\nN={n['placebo']}",  align = "decimal"),
    drug_50  = col_spec(label = "Drug 50\nN={n['drug_50']}",  align = "decimal"),
    drug_100 = col_spec(label = "Drug 100\nN={n['drug_100']}", align = "decimal"),
    Total    = col_spec(label = "Total\nN={n['Total']}",    align = "decimal")
  ) |>
  sort_rows(by = c("soc_n", "n_total"), descending = c(TRUE, TRUE))

# ---- Example 3: Format string + na_text for clean numeric display ----
#
# `cdisc_eff_estimates` ships four competing efficacy models with
# pre-computed numeric estimates, 95\% CI bounds (NA on the MMRM
# row), and a nominal p-value. `format =` pins the printed
# precision; `na_text` renders the missing CI bounds as a dash
# rather than a literal "NA". `valign = "top"` keeps the multi-
# line cell text aligned to the top.
tabular(cdisc_eff_estimates, titles = "Treatment-effect estimates by model") |>
  cols(
    model    = col_spec(usage = "group",  label = "Model",   valign = "top"),
    estimate = col_spec(label = "Estimate", align = "decimal", format = "\%.2f"),
    lower_ci = col_spec(
      label   = "Lower\n95\% CI",
      align   = "decimal",
      format  = "\%.2f",
      na_text = "--"
    ),
    upper_ci = col_spec(
      label   = "Upper\n95\% CI",
      align   = "decimal",
      format  = "\%.2f",
      na_text = "--"
    ),
    p_value  = col_spec(
      label   = "p-value",
      align   = "decimal",
      format  = "\%.4f"
    )
  )

# ---- Example 4: Per-column width + halign override for vitals ----
#
# `width` accepts a numeric (inches), a CSS-style string ("1.5in",
# "20\%"), or `"auto"`. Centering the visit column under a wider
# group-column setup demonstrates the alignment cascade —
# col_spec@align beats the engine default but yields to a more
# specific style() rule downstream.
n <- stats::setNames(cdisc_saf_n$n, cdisc_saf_n$arm_short)
tabular(
  cdisc_saf_vital,
  titles = "Vital Signs at Baseline and End of Treatment"
) |>
  cols(
    paramcd    = col_spec(visible = FALSE),
    param      = col_spec(usage = "group", label = "Parameter",
                          width = "1.6in"),
    visit      = col_spec(usage = "group", label = "Visit",
                          width = "1.2in", align = "center"),
    stat_label = col_spec(label = "Statistic", width = "1.0in"),
    placebo    = col_spec(
      label = "Placebo\nN={n['placebo']}",
      align = "decimal", width = "0.9in"
    ),
    drug_50    = col_spec(
      label = "Drug 50\nN={n['drug_50']}",
      align = "decimal", width = "0.9in"
    ),
    drug_100   = col_spec(
      label = "Drug 100\nN={n['drug_100']}",
      align = "decimal", width = "0.9in"
    )
  )

# ---- Example 5: Non-collapsing `id` stub for a panelled table ----
#
# `usage = "id"` marks `stat_label` ("n", "Mean", "SD", ...) as a
# row identifier: like `display` it shows on every row, but it also
# joins the stub, so it repeats on each horizontal panel created by
# `paginate(panels = 2)`. On HTML / Markdown (no page width) the
# panels collapse into one scrollable table with a "Panel 1 / Panel
# 2" header note; on RTF / Word each panel is its own page with the
# `variable` + `stat_label` stub repeated.
n <- stats::setNames(cdisc_saf_n$n, cdisc_saf_n$arm_short)
tabular(
  cdisc_saf_demo,
  titles = c("Table 14.1.1", "Demographics", "Safety Population")
) |>
  cols(
    variable   = col_spec(usage = "group", group_display = "column",
                          label = "Parameter"),
    stat_label = col_spec(usage = "id", label = "Statistic"),
    placebo    = col_spec(label = "Placebo\nN={n['placebo']}",  align = "decimal"),
    drug_50    = col_spec(label = "Drug 50\nN={n['drug_50']}",  align = "decimal"),
    drug_100   = col_spec(label = "Drug 100\nN={n['drug_100']}", align = "decimal"),
    Total      = col_spec(label = "Total\nN={n['Total']}",    align = "decimal")
  ) |>
  paginate(panels = 2)

}
