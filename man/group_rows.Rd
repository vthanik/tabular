tabular(cdisc_saf_vital, titles = "Vital Signs by Parameter and Visit") |>
  cols(
    paramcd = col_spec(visible = FALSE),
    param = "Parameter",
    visit = "Visit",
    stat_label = "Statistic",
    placebo = "Placebo\nN={n['placebo']}",
